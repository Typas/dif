# Binary test images live in LFS, not the git object store.
# Scoped to testdata/ so source-tree images (web/, spec/) stay normal blobs.
testdata/**/*.tiff filter=lfs diff=lfs merge=lfs -text
testdata/**/*.tif  filter=lfs diff=lfs merge=lfs -text
testdata/**/*.png  filter=lfs diff=lfs merge=lfs -text
testdata/**/*.gif  filter=lfs diff=lfs merge=lfs -text
testdata/**/*.webp filter=lfs diff=lfs merge=lfs -text
testdata/**/*.bmp  filter=lfs diff=lfs merge=lfs -text
testdata/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
testdata/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tsv filter=lfs diff=lfs merge=lfs -text
